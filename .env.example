# Gmail Configuration
# Path to your Google OAuth credentials JSON file
GOOGLE_CREDENTIALS_PATH=credentials.json

# Slack Configuration
# Incoming webhook URL (get from Slack App > Incoming Webhooks)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Document Scanner Bot Configuration
# Slack Bot Token (xoxb-...) - get from Slack App > OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-bot-token
# Slack Signing Secret - get from Slack App > Basic Information
SLACK_SIGNING_SECRET=your-signing-secret
# Anthropic API Key for Claude Vision
ANTHROPIC_API_KEY=sk-ant-your-api-key

# Agent Configuration
# Email subject pattern to watch for (supports regex)
# Matches forwarded OPIS emails: "Fw: OPIS Wholesale Racks with OPIS Spot Mean"
COST_EMAIL_SUBJECT_PATTERN=OPIS Wholesale|OPIS Spot

# How often to check for new emails (in seconds)
POLL_INTERVAL=60

# Sender email to watch for (forwarded emails come from this address)
WATCH_SENDER_EMAIL=ayush@foliox.ai

# Reply configuration
# Email address to send pricing summaries to
REPLY_TO_EMAIL=bsims@pakasak.net
# Email address to CC on replies
CC_EMAIL=ayush@foliox.ai

# Data storage
PRICE_HISTORY_FILE=price_history.json
DATA_PATH=data

# ============================================================
# AI Marketing Lead Agent Configuration
# ============================================================

# Slack webhook for marketing content suggestions
# Can reuse SLACK_WEBHOOK_URL or use a separate channel
MARKETING_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Slack App Token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=xapp-your-app-token

# Google Gemini API Key (for image generation)
GEMINI_API_KEY=your-gemini-api-key

# Banana.dev API Key (Nano Banana for Stable Diffusion image generation)
BANANA_API_KEY=your-banana-api-key

# Google Custom Search API (for news scanning)
GOOGLE_SEARCH_API_KEY=your-google-search-api-key
GOOGLE_SEARCH_CX=your-custom-search-engine-id

# Foliox Website API (WordPress REST API or custom CMS)
WEBSITE_API_URL=https://foliox.ai/wp-json
WEBSITE_API_KEY=your-website-api-key

# LinkedIn Publishing
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token
LINKEDIN_ORG_ID=your-linkedin-organization-id

# Marketing Agent Settings
MARKETING_SCAN_INTERVAL=3600
MARKETING_NUM_SUGGESTIONS=3
MARKETING_OUTPUT_DIR=marketing_output
MARKETING_SERVER_PORT=3001
