# Gmail Configuration
# Path to your Google OAuth credentials JSON file
GOOGLE_CREDENTIALS_PATH=credentials.json

# Slack Configuration
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=C0123456789

# Agent Configuration
# Email subject pattern to watch for (supports regex)
# Matches forwarded OPIS emails: "Fw: OPIS Wholesale Racks with OPIS Spot Mean"
COST_EMAIL_SUBJECT_PATTERN=OPIS Wholesale|OPIS Spot

# How often to check for new emails (in seconds)
POLL_INTERVAL=60

# Sender email to watch for (forwarded emails come from this address)
WATCH_SENDER_EMAIL=ayush@foliox.ai

# Data storage
PRICE_HISTORY_FILE=price_history.json
DATA_PATH=data
