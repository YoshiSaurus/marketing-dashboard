# Gmail Configuration
# Path to your Google OAuth credentials JSON file
GOOGLE_CREDENTIALS_PATH=credentials.json

# Slack Configuration
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=C0123456789

# Agent Configuration
# Email subject pattern to watch for (supports regex)
# Default is set for OPIS fuel pricing emails
COST_EMAIL_SUBJECT_PATTERN=OPIS Wholesale|OPIS Spot

# How often to check for new emails (in seconds)
POLL_INTERVAL=60

# Sender email to watch for OPIS pricing emails
WATCH_SENDER_EMAIL=opisadmin@opisnet.com

# Price history file location (for trend analysis)
PRICE_HISTORY_FILE=price_history.json
