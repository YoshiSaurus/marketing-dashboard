# Gmail Configuration
# Path to your Google OAuth credentials JSON file
GOOGLE_CREDENTIALS_PATH=credentials.json

# Slack Configuration
# Incoming webhook URL (get from Slack App > Incoming Webhooks)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL


# Agent Configuration
# Email subject pattern to watch for (supports regex)
# Matches forwarded OPIS emails: "Fw: OPIS Wholesale Racks with OPIS Spot Mean"
COST_EMAIL_SUBJECT_PATTERN=OPIS Wholesale|OPIS Spot

# How often to check for new emails (in seconds)
POLL_INTERVAL=60

# Sender email to watch for (forwarded emails come from this address)
WATCH_SENDER_EMAIL=ayush@foliox.ai

# Reply configuration
# Email address to send pricing summaries to
REPLY_TO_EMAIL=bsims@pakasak.net
# Email address to CC on replies
CC_EMAIL=ayush@foliox.ai

# Data storage
PRICE_HISTORY_FILE=price_history.json
DATA_PATH=data
